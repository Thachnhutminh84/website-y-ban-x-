# Database Configuration
DB_HOST=localhost
DB_NAME=ubnd_longhiep
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Application Settings
APP_NAME="UBND Xã Long Hiệp"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# Security
ADMIN_INIT_PASSWORD=
SESSION_LIFETIME=3600
CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_TIMEOUT=300

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Email Configuration (optional)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@longhiep.gov.vn
MAIL_FROM_NAME="UBND Xã Long Hiệp"

# Backup Settings
BACKUP_ENABLED=true
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30

# Logging
LOG_ENABLED=true
LOG_LEVEL=info
LOG_PATH=logs/

# Cache Settings
CACHE_ENABLED=false
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# API Settings
API_ENABLED=true
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60
